# LLM provider: gemini | ollama
LLM_PROVIDER=ollama

# Gemini (used only if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3.5:4b
OLLAMA_VISION_MODEL=moondream:latest
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
OLLAMA_TIMEOUT_SEC=45

# Visual LLM budgeting
VISUAL_LLM_BUDGET_MODE=adaptive
VISUAL_LLM_MAX_FRAMES=30
VISUAL_LLM_MIN_FRAMES=8
VISUAL_LLM_FRAME_RATIO=0.2
VISUAL_LLM_MAX_PER_MIN=12
